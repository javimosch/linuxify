#!/usr/bin/env node

/**
 * Linuxify CLI Entry Point
 * Handles interactive setup and starts the application
 */

const path = require('path');
const fs = require('fs');
const { spawnSync } = require('child_process');
const readline = require('readline');

// Color codes for terminal output
const colors = {
  reset: '\x1b[0m',
  bright: '\x1b[1m',
  green: '\x1b[32m',
  yellow: '\x1b[33m',
  red: '\x1b[31m',
  blue: '\x1b[36m',
  dim: '\x1b[2m'
};

// Create readline interface
const rl = readline.createInterface({
  input: process.stdin,
  output: process.stdout
});

// Helper functions
function log(message, color = 'reset') {
  console.log(`${colors[color]}${message}${colors.reset}`);
}

function prompt(question) {
  return new Promise((resolve) => {
    rl.question(`${colors.blue}?${colors.reset} ${question} `, (answer) => {
      resolve(answer.toLowerCase().trim());
    });
  });
}

function isRunningAsRoot() {
  return process.getuid?.() === 0;
}

function isSudoersConfigured() {
  try {
    const result = spawnSync('sudo', ['-n', 'true'], {
      stdio: 'pipe',
      timeout: 2000
    });
    return result.status === 0;
  } catch {
    return false;
  }
}

function checkSudoersRules() {
  try {
    // Try running a test command with sudo without password
    const result = spawnSync('sudo', ['-n', 'systemctl', 'status', 'systemd'], {
      stdio: 'pipe',
      timeout: 2000
    });
    return result.status === 0;
  } catch {
    return false;
  }
}

async function setupSudoers() {
  log('\n' + '='.repeat(60), 'bright');
  log('SUDOERS CONFIGURATION SETUP', 'bright');
  log('='.repeat(60) + '\n', 'bright');

  log('Linuxify needs sudo access to manage system services and disk cleanup.', 'yellow');
  log('This setup will configure passwordless sudo for specific commands.\n', 'yellow');

  if (isSudoersConfigured()) {
    log('✓ Your system appears to already allow passwordless sudo', 'green');
    const proceed = await prompt('Reconfigure sudoers rules? (y/n)');
    if (proceed !== 'y') {
      return true;
    }
  }

  log('\nRequired sudoers rules for Linuxify:\n', 'yellow');
  log('-'.repeat(60), 'dim');

  const sudoersRules = `# Linuxify - systemctl commands
%sudo ALL=(ALL) NOPASSWD: /bin/systemctl disable *
%sudo ALL=(ALL) NOPASSWD: /bin/systemctl stop *
%sudo ALL=(ALL) NOPASSWD: /bin/systemctl mask *
%sudo ALL=(ALL) NOPASSWD: /bin/systemctl unmask *
%sudo ALL=(ALL) NOPASSWD: /bin/systemctl enable *
%sudo ALL=(ALL) NOPASSWD: /bin/systemctl start *
%sudo ALL=(ALL) NOPASSWD: /bin/systemctl restart *
%sudo ALL=(ALL) NOPASSWD: /bin/systemctl reload *

# Linuxify - cleanup commands
%sudo ALL=(ALL) NOPASSWD: /usr/bin/apt clean
%sudo ALL=(ALL) NOPASSWD: /usr/bin/apt autoremove -y
%sudo ALL=(ALL) NOPASSWD: /usr/bin/apt autoremove --purge -y
%sudo ALL=(ALL) NOPASSWD: /usr/bin/journalctl --vacuum-time=7d
%sudo ALL=(ALL) NOPASSWD: /usr/bin/journalctl --vacuum-size=500M
%sudo ALL=(ALL) NOPASSWD: /usr/bin/flatpak remove --unused -y
%sudo ALL=(ALL) NOPASSWD: /usr/bin/dnf clean all
%sudo ALL=(ALL) NOPASSWD: /usr/bin/pacman -Sc --noconfirm
%sudo ALL=(ALL) NOPASSWD: /usr/bin/rm -rf /tmp/*
%sudo ALL=(ALL) NOPASSWD: /usr/bin/rm -rf /var/tmp/*
%sudo ALL=(ALL) NOPASSWD: /usr/bin/rm -rf /root/.cache
%sudo ALL=(ALL) NOPASSWD: /usr/bin/find /root -name "\.old" -delete`;

  console.log(sudoersRules);
  log('-'.repeat(60) + '\n', 'dim');

  log('This will be added to your sudoers file automatically.', 'yellow');
  const configure = await prompt('Configure sudoers automatically? (y/n)');
  
  if (configure === 'y') {
    log('\n' + '='.repeat(60), 'bright');
    log('RUNNING SUDOERS CONFIGURATION', 'bright');
    log('='.repeat(60) + '\n', 'bright');
    
    log('You will be prompted for your sudo password...', 'yellow');
    log('(This is required to edit the sudoers file securely)\n', 'yellow');
    
    // Get the path to setup.sh
    const setupScriptPath = path.join(__dirname, '..', 'setup.sh');
    
    // Run the setup script with sudo
    const result = spawnSync('sudo', ['bash', setupScriptPath], { 
      stdio: 'inherit',
      timeout: 60000 // 60 second timeout
    });
    
    if (result.status === 0) {
      log('\n✓ Sudoers configured successfully!', 'green');
      
      // Test the configuration
      await new Promise(resolve => setTimeout(resolve, 1000)); // Wait a moment for changes to take effect
      
      log('Verifying sudoers configuration...', 'yellow');
      if (checkSudoersRules()) {
        log('✓ Configuration verified - passwordless sudo is working!', 'green');
        return true;
      } else {
        log('⚠ Configuration may be working but verification test inconclusive', 'yellow');
        log('This is normal - the configuration should still work.\n', 'yellow');
        return true;
      }
    } else if (result.status === 1) {
      log('\n✗ Setup script reported an error', 'red');
      log('Please review the error messages above\n', 'yellow');
      return false;
    } else if (result.signal === 'SIGTERM') {
      log('\n✗ Setup script timed out', 'red');
      log('Please try again or configure manually\n', 'yellow');
      return false;
    } else {
      log('\n✗ Sudoers configuration was cancelled or failed', 'red');
      log('You can configure it manually later by running: sudo bash setup.sh\n', 'yellow');
      return false;
    }
  } else {
    log('\nYou can configure sudoers manually later by running:', 'yellow');
    log('  sudo bash setup.sh\n', 'blue');
    log('Or for interactive sudoers editing:', 'yellow');
    log('  sudo visudo\n', 'blue');
    return true;
  }
}

async function setupModeSelection() {
  log('\n' + '='.repeat(60), 'bright');
  log('SETUP MODE SELECTION', 'bright');
  log('='.repeat(60) + '\n', 'bright');

  log('Linuxify can be configured in two ways:\n', 'yellow');

  log('1. SUDOERS MODE (Recommended for security-conscious users)', 'bright');
  log('   ✓ Configure sudoers file once', 'green');
  log('   ✓ Run Linuxify as regular user afterwards', 'green');
  log('   ✓ Commands execute with limited sudo scope', 'green');
  log('   ✗ Requires visudo configuration', 'dim');
  log('   ✗ Exposes commands to sudoers (potential privilege escalation vector)', 'dim');
  log('');

  log('2. SUDO RUN MODE (Simpler, full control)', 'bright');
  log('   ✓ Run Linuxify directly with sudo: sudo npx linuxify', 'green');
  log('   ✓ No sudoers configuration needed', 'green');
  log('   ✓ Full root privileges, complete control', 'green');
  log('   ✓ Easiest setup (just one command)', 'green');
  log('   ⚠ Web interface runs as root (security consideration)', 'yellow');
  log('   ⚠ Only access from localhost recommended', 'yellow');
  log('');

  const choice = await prompt('Which mode do you prefer? (1=sudoers, 2=sudo-run, 0=skip)');

  if (choice === '1') {
    log('\n✓ Sudoers mode selected\n', 'green');
    return 'sudoers';
  } else if (choice === '2') {
    log('\n✓ Sudo run mode selected\n', 'green');
    
    if (isRunningAsRoot()) {
      log('✓ Already running with sudo - ready to go!\n', 'green');
      return 'sudo-run-active';
    } else {
      log('\n' + '='.repeat(60), 'yellow');
      log('⚠ SUDO RUN MODE INSTRUCTIONS', 'yellow');
      log('='.repeat(60) + '\n', 'yellow');
      
      log('To run Linuxify in sudo mode, use:\n', 'bright');
      log('  sudo PATH=$PATH bash bin/linuxify.sh\n', 'blue');
      
      log('Or preserve entire environment:\n', 'bright');
      log('  sudo -E bash bin/linuxify.sh\n', 'blue');
      
      log('Or with full path to node:\n', 'bright');
      log(`  sudo ${process.execPath} bin/linuxify\n`, 'blue');
      
      log('Security Notes:', 'yellow');
      log('  • The web interface will run as root', 'dim');
      log('  • Only access from localhost (127.0.0.1)', 'dim');
      log('  • Do not expose to network', 'dim');
      log('  • All operations have full root access', 'dim');
      log('');
      
      return 'sudo-run-inactive';
    }
  } else {
    log('\nSetup skipped\n', 'yellow');
    return 'skip';
  }
}

async function runSetupWizard() {
  log('\n' + '╔' + '═'.repeat(58) + '╗', 'bright');
  log('║' + ' '.repeat(58) + '║', 'bright');
  log('║' + '  Welcome to Linuxify - Linux System Optimizer'.padEnd(57) + '║', 'bright');
  log('║' + ' '.repeat(58) + '║', 'bright');
  log('╚' + '═'.repeat(58) + '╝\n', 'bright');

  const skipSetup = await prompt('Run setup wizard? (y/n)');
  
  if (skipSetup !== 'y') {
    log('\nSkipping setup. You can run it anytime with: npx linuxify --setup\n', 'yellow');
    return true;
  }

  // Check if we're in the right directory
  const serverPath = path.join(process.cwd(), 'server.js');
  if (!fs.existsSync(serverPath)) {
    log('\n✗ Error: server.js not found in current directory', 'red');
    log('Make sure you\'re in the Linuxify project directory\n', 'yellow');
    process.exit(1);
  }

  // Get user's preferred setup mode
  const mode = await setupModeSelection();

  // Handle based on selected mode
  if (mode === 'sudoers') {
    // Run sudoers setup
    const sudoersSuccess = await setupSudoers();
    if (!sudoersSuccess) {
      const cont = await prompt('Continue without sudoers configuration? (y/n)');
      if (cont !== 'y') {
        rl.close();
        process.exit(0);
      }
    }
  } else if (mode === 'sudo-run-active') {
    // Already running as root, ready to go
    log('✓ Everything is set up!\n', 'green');
  } else if (mode === 'sudo-run-inactive') {
    // Instructions already shown by setupModeSelection()
    log('Run the command above to start Linuxify with sudo mode.\n', 'yellow');
    rl.close();
    process.exit(0);
  } else if (mode === 'skip') {
    log('You can run setup anytime with: npx linuxify --setup\n', 'yellow');
  }

  log('\n✓ Setup complete! Starting Linuxify...\n', 'green');
  return true;
}

async function main() {
  // Parse command line arguments
  const args = process.argv.slice(2);
  
  // Check for help flag
  if (args.includes('--help') || args.includes('-h')) {
    log('\n' + '═'.repeat(60), 'bright');
    log('Linuxify - Linux System Optimizer', 'bright');
    log('═'.repeat(60) + '\n', 'bright');
    
    log('Usage: linuxify [options]\n', 'bright');
    
    log('Options:', 'bright');
    log('  --setup, -s       Run setup wizard before starting', 'blue');
    log('  --skip-setup      Skip setup and start directly', 'blue');
    log('  --help, -h        Show this help message', 'blue');
    log('  --version, -v     Show version\n', 'blue');
    
    log('Examples:', 'bright');
    log('  npx linuxify              # Interactive setup then start', 'dim');
    log('  npx linuxify --skip-setup # Start without setup', 'dim');
    log('  npx linuxify --setup      # Run setup wizard only\n', 'dim');
    
    rl.close();
    process.exit(0);
  }

  // Check for version flag
  if (args.includes('--version') || args.includes('-v')) {
    const packageJson = require(path.join(__dirname, '..', 'package.json'));
    log(`Linuxify v${packageJson.version}\n`, 'green');
    rl.close();
    process.exit(0);
  }

  // Check for skip-setup flag
  const skipSetup = args.includes('--skip-setup');

  // Run setup wizard if not skipped
  if (!skipSetup) {
    await runSetupWizard();
  } else {
    log('\nStarting Linuxify...\n', 'green');
  }

  // Start the server
  rl.close();
  
  try {
    require(path.join(__dirname, '..', 'server.js'));
  } catch (error) {
    log(`\n✗ Error starting server: ${error.message}`, 'red');
    process.exit(1);
  }
}

// Handle Ctrl+C gracefully
process.on('SIGINT', () => {
  log('\n\nGoodbye!', 'yellow');
  rl.close();
  process.exit(0);
});

// Run main function
main().catch((error) => {
  log(`\n✗ Fatal error: ${error.message}`, 'red');
  rl.close();
  process.exit(1);
});
